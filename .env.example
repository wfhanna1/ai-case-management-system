# Copy this file to .env and adjust values for your local environment.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# ASP.NET / .NET runtime
# ---------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=intake_processor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
# Host port mapped to the postgres container (change if 5432 is already in use)
POSTGRES_HOST_PORT=5432

# ---------------------------------------------------------------------------
# RabbitMQ
# ---------------------------------------------------------------------------
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=changeme
# AMQP port
RABBITMQ_AMQP_PORT=5672
# Management UI port  (http://localhost:15672)
RABBITMQ_MGMT_PORT=15672

# ---------------------------------------------------------------------------
# Qdrant vector database
# ---------------------------------------------------------------------------
# HTTP port (REST API)
QDRANT_HTTP_PORT=6333
# gRPC port
QDRANT_GRPC_PORT=6334

# ---------------------------------------------------------------------------
# Host port mappings for application services
# ---------------------------------------------------------------------------
# API service (ASP.NET Core listens on 8080 inside the container)
API_HOST_PORT=5003
# OCR worker service
OCR_WORKER_HOST_PORT=5001
# RAG service
RAG_SERVICE_HOST_PORT=5002
# Frontend (nginx listens on 80 inside the container)
FRONTEND_HOST_PORT=3000

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
# Prometheus
PROMETHEUS_HOST_PORT=9090
# Grafana (uses 3001 to avoid conflict with frontend on 3000)
GRAFANA_HOST_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin
# Loki (log aggregation)
LOKI_HOST_PORT=3100
# Loki Docker logging driver push URL
# macOS/Windows (Docker Desktop): http://host.docker.internal:3100/loki/api/v1/push
# Linux (Docker Engine):          http://localhost:3100/loki/api/v1/push
LOKI_DRIVER_URL=http://host.docker.internal:3100/loki/api/v1/push
# Tempo (distributed tracing -- HTTP API on 3200)
TEMPO_HOST_PORT=3200
# OTLP exporter endpoint (services use Docker internal network by default)
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
