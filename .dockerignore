# .dockerignore — repo root build context
# Keep this file maintained alongside Dockerfiles to minimise image build context size.

# ---------------------------------------------------------------------------
# .NET build artefacts
# ---------------------------------------------------------------------------
**/bin/
**/obj/
**/*.user
**/*.suo
**/*.vs/
**/.vs/

# ---------------------------------------------------------------------------
# Node / frontend
# ---------------------------------------------------------------------------
src/ClientApp/node_modules/
src/ClientApp/dist/
src/ClientApp/.vite/

# ---------------------------------------------------------------------------
# Git & IDE
# ---------------------------------------------------------------------------
.git/
.github/
.gitignore
.gitattributes
.editorconfig
.vscode/
.idea/
*.code-workspace

# ---------------------------------------------------------------------------
# Docker files themselves (not needed inside the build context layers)
# ---------------------------------------------------------------------------
**/Dockerfile
docker-compose*.yml
.dockerignore

# ---------------------------------------------------------------------------
# Environment & secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Test output and coverage
# ---------------------------------------------------------------------------
**/TestResults/
**/coverage/
**/*.trx
**/*.opencover.xml

# ---------------------------------------------------------------------------
# OS artefacts
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
